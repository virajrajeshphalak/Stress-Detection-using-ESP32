#include <WiFi.h>
#include <WiFiClient.h>
#include <Wire.h>
#include "MAX30105.h"
#include <Adafruit_SSD1306.h>
#include <Adafruit_GFX.h>

const char* ssid = "Viraj's S25+";
const char* password = "Viraj123456";

String apiKey = "6GHKNKRMOKYQHPG2";
const char* server = "api.thingspeak.com";

#define GSR_PIN 34
#define LED_PIN 2
#define I2C_SDA 21
#define I2C_SCL 22

MAX30105 particleSensor;
Adafruit_SSD1306 display(128, 64, &Wire, -1);

const int GSR_SMOOTH_SAMPLES = 10;
const int RATE_SIZE = 6;

const float GSR_LOW_THRESHOLD = 700;
const float GSR_HIGH_THRESHOLD = 900;
const int HR_LOW_THRESHOLD = 80;
const int HR_HIGH_THRESHOLD = 100;

const int IR_THRESHOLD = 15000;
const int GSR_CONTACT_THRESHOLD = 80;

float gsrValues[GSR_SMOOTH_SAMPLES];
int gsrIndex = 0;
float gsrSmoothed = 0;
int rawGSR = 0;

int rates[RATE_SIZE];
int rateSpot = 0;
long lastBeat = 0;
int beatAvg = 0;

bool fingerDetected = false;

long irPrev = 0;
long irCurr = 0;
long irDiff = 0;

enum StressLevel { STRESS_LOW = 0, STRESS_MEDIUM = 1, STRESS_HIGH = 2 };
StressLevel currentStress = STRESS_MEDIUM;

unsigned long lastDisplay = 0;
unsigned long lastThingSpeak = 0;

void setup() {
  Serial.begin(115200);
  delay(500);

  Wire.begin(I2C_SDA, I2C_SCL);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    while (1);
  }

  display.clearDisplay();
  display.setTextSize(2);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(10, 20);
  display.println("HELLO");
  display.display();
  delay(2000);

  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    while (1);
  }

  particleSensor.setup(60, 4, 2, 100, 411, 16384);

  pinMode(LED_PIN, OUTPUT);
  pinMode(GSR_PIN, INPUT);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }
}

void loop() {

  readGSR();
  detectFinger();
  processHeartRate();
  calculateStressLevel();

  if (millis() - lastDisplay >= 500) {
    updateDisplay();
    lastDisplay = millis();
  }

  if (millis() - lastThingSpeak >= 15000) {
    sendToThingSpeak();
    lastThingSpeak = millis();
  }

  printSerial();
}

void readGSR() {
  rawGSR = analogRead(GSR_PIN);

  float voltage = (rawGSR / 4095.0) * 3.3;
  float current = voltage * 1000;

  gsrValues[gsrIndex] = current;
  gsrIndex = (gsrIndex + 1) % GSR_SMOOTH_SAMPLES;

  gsrSmoothed = 0;
  for (int i = 0; i < GSR_SMOOTH_SAMPLES; i++) {
    gsrSmoothed += gsrValues[i];
  }
  gsrSmoothed /= GSR_SMOOTH_SAMPLES;
}

void detectFinger() {
  long ir = particleSensor.getIR();

  if (ir > IR_THRESHOLD && rawGSR > GSR_CONTACT_THRESHOLD)
    fingerDetected = true;
  else
    fingerDetected = false;

  if (!fingerDetected) {
    beatAvg = 0;
    gsrSmoothed = 0;
  }
}

void processHeartRate() {

  if (!fingerDetected) return;

  irCurr = particleSensor.getIR();
  irDiff = irCurr - irPrev;

  static bool rising = false;

  if (irDiff > 0) {
    rising = true;
  }

  if (irDiff < 0 && rising) {
    long now = millis();
    long delta = now - lastBeat;
    lastBeat = now;

    float bpm = 60.0 / (delta / 1000.0);

    if (bpm > 40 && bpm < 180) {
      rates[rateSpot++] = bpm;
      rateSpot %= RATE_SIZE;

      beatAvg = 0;
      for (int i = 0; i < RATE_SIZE; i++) {
        beatAvg += rates[i];
      }
      beatAvg /= RATE_SIZE;
    }

    rising = false;
  }

  irPrev = irCurr;
}

void calculateStressLevel() {
  if (!fingerDetected) {
    currentStress = STRESS_LOW;
    digitalWrite(LED_PIN, LOW);
    return;
  }

  int score = 0;

  if (beatAvg > HR_HIGH_THRESHOLD) score++;
  if (gsrSmoothed > GSR_HIGH_THRESHOLD) score++;

  if (score == 2) currentStress = STRESS_HIGH;
  else if (score == 0 && beatAvg < HR_LOW_THRESHOLD && gsrSmoothed < GSR_LOW_THRESHOLD)
    currentStress = STRESS_LOW;
  else
    currentStress = STRESS_MEDIUM;

  updateLED();
}

void updateLED() {
  if (currentStress == STRESS_LOW)
    digitalWrite(LED_PIN, (millis()/1000)%2);
  else if (currentStress == STRESS_MEDIUM)
    digitalWrite(LED_PIN, (millis()/500)%2);
  else
    digitalWrite(LED_PIN, HIGH);
}

void updateDisplay() {
  display.clearDisplay();
  display.setTextSize(2);

  display.setCursor(0, 0);
  display.print("HR:");
  display.println(beatAvg);

  display.setCursor(0, 25);
  display.print("GSR:");
  display.println((int)gsrSmoothed);

  display.setCursor(0, 50);

  if (!fingerDetected) display.println("NO FINGER");
  else if (currentStress == STRESS_LOW) display.println("LOW");
  else if (currentStress == STRESS_MEDIUM) display.println("MED");
  else display.println("HIGH");

  display.display();
}

void printSerial() {
  String stressText;

  if (!fingerDetected) stressText = "NO_FINGER";
  else if (currentStress == STRESS_LOW) stressText = "LOW";
  else if (currentStress == STRESS_MEDIUM) stressText = "MED";
  else stressText = "HIGH";

  Serial.printf("HR:%d | IR:%ld | GSR:%.0f | Stress:%s\n",
                beatAvg, irCurr, gsrSmoothed, stressText.c_str());
}

void sendToThingSpeak() {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClient client;

  if (client.connect(server, 80)) {

    String url = "/update?api_key=" + apiKey +
                 "&field1=" + String(beatAvg) +
                 "&field2=" + String((int)gsrSmoothed) +
                 "&field3=" + String(currentStress) +
                 "&field4=" + String(irCurr);

    client.print(String("GET ") + url + " HTTP/1.1\r\n" +
                 "Host: api.thingspeak.com\r\n"
                 "Connection: close\r\n\r\n");

    delay(100);
    client.stop();
  }
}